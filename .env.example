# Nuxt Studio Token (for local development preview)
NUXT_STUDIO_TOKEN=

# Nuxt Studio GitHub Token (for production Git operations)
# Create a Personal Access Token (PAT) with 'repo' scope
STUDIO_GITHUB_TOKEN=

# Cloudflare D1 Database (for Nuxt Content database in production)
# These are usually handled by wrangler/secrets in CI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
