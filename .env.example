# Nuxt Studio Token (for local development preview)
NUXT_STUDIO_TOKEN=

# GitHub OAuth (for production Studio access and Git operations)
# Create an OAuth App in GitHub Settings > Developer settings
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# Cloudflare D1 Database (for Nuxt Content database in production)
# These are usually handled by wrangler/secrets in CI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
