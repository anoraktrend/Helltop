# Nuxt Studio Token (Legacy)
NUXT_STUDIO_TOKEN=
STUDIO_GITHUB_TOKEN=

# Turso / libSQL (StudioCMS Database)
CMS_LIBSQL_URL=libsql://your-db-name.turso.io
CMS_LIBSQL_AUTH_TOKEN=your-auth-token

# StudioCMS Security
# Generate with: openssl rand --base64 16
CMS_ENCRYPTION_KEY=

# Cloudflare (Optional/Legacy)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
