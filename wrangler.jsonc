{
	"name": "helltop",
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["nodejs_compat"],
	"routes": [
		{ "pattern": "helltop.net", "custom_domain": true }
	],
	"assets": {
		"directory": "./dist/",
		"binding": "ASSETS"
	},
	"vars": {
		"ENVIRONMENT": "production"
	},
	"observability": {
		"enabled": true
	}
}
