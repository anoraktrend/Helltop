{
	"name": "helltop",
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["nodejs_compat"],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "35060e7735dd4c09ac7e7ff9f206be35"
		},
	],
	"routes": [
		{ "pattern": "helltop.net", "custom_domain": true }
	],
	"assets": {
		"directory": "./dist/",
		"binding": "ASSETS"
	},
	"vars": {
		"ENVIRONMENT": "production"
	},
	"observability": {
		"enabled": true
	}
}
