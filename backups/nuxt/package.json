{
  "name": "content-wind",
  "description": "A personal website theme powered by Nuxt Content, TailwindCSS, Iconify and Vue components.",
  "private": false,
  "version": "2.0.0",
  "main": "nuxt.config.ts",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --no-deprecation' nuxi dev",
    "build": "pnpm generate:rss && NODE_OPTIONS='--max-old-space-size=4096 --no-deprecation' nuxi build",
    "generate:rss": "npx tsx scripts/generate-rss.ts",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "lint": "eslint .",
    "update-blog-index": "node scripts/update-blog-index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:nuxt": "vitest --project nuxt"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@iconify-json/lucide": "^1.2.97",
    "@iconify-json/simple-icons": "^1.2.73",
    "@nuxt/content": "^3.12.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "1.0.0-beta.1",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@pnpm/linux-x64": "10.32.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@unhead/vue": "^2.1.12",
    "better-sqlite3": "^12.8.0",
    "markdown-it": "^14.1.1",
    "nuxi": "^3.34.0",
    "nuxt": "^4.4.2",
    "rss": "^1.2.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.73.0"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@iconify-json/catppuccin": "^1.2.17",
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/rss": "^0.0.32",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "baseline-browser-mapping": "^2.10.7",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "nuxt-security": "^2.5.1",
    "nuxt-studio": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "serialize-javascript": "^7.0.3",
      "undici": "^7.24.0",
      "vue-router": "5.0.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  }
}
