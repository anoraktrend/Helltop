---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Link } from 'astro-link';

const blog = await getCollection('blog');

// Filter out drafts and sort posts by date (if available) or title
const validBlogPosts = blog.filter((post) => post.data.draft !== true);
const sortedPosts = validBlogPosts.sort((a, b) => {
  if (a.data.date && b.data.date) {
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  }
  return a.data.title.localeCompare(b.data.title);
});
---

<Layout title="Blog | Helltop">
  <section class="py-12">
    <div class="flex items-center gap-8 mb-20">
      <div class="size-4 bg-tron-blue rounded-full shadow-[0_0_15px_rgba(203,166,247,1)] animate-pulse"></div>
      <h1 class="text-4xl sm:text-5xl font-black text-text-main uppercase tracking-[0.6em] tron-glow-text whitespace-nowrap">
        The Archive
      </h1>
      <div class="h-[2px] flex-grow bg-gradient-to-r from-tron-blue/40 to-transparent shadow-[0_0_10px_rgba(203,166,247,0.2)]"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 sm:gap-16">
      {sortedPosts.map((post) => (
        <article class="group relative">
          <!-- Hover Glow -->
          <div class="absolute -inset-2 bg-tron-blue/10 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          
          <div class="tron-card h-full rounded-3xl border-tron-blue/15 hover:border-tron-blue/60 transition-all duration-700 overflow-hidden flex flex-col">
            <Link href={`/blog/${post.data.slug}`} class="flex flex-col h-full p-8" aria-label={`Read post: ${post.data.title}`}>
              <div class="flex justify-between items-start mb-6">
                <div class="flex flex-wrap gap-3">
                  {post.data.tags && post.data.tags.map((tag) => (
                    <span class="px-3 py-1 bg-tron-blue/5 text-tron-blue text-[10px] font-black uppercase tracking-widest rounded-lg border border-tron-blue/20 group-hover:border-tron-blue/50 transition-colors">
                      {tag}
                    </span>
                  ))}
                </div>
                {post.data.date && (
                  <time class="text-text-overlay font-mono text-[10px] ml-auto uppercase tracking-widest bg-ctp-crust/40 px-3 py-1 rounded-full border border-white/5">
                    {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </time>
                )}
              </div>
              
              <h2 class="text-2xl font-black text-text-main group-hover:text-tron-blue transition-colors mb-4 leading-tight uppercase tracking-tighter">
                {post.data.title}
              </h2>
              
              <p class="text-text-muted text-sm leading-relaxed mb-8 line-clamp-3 font-mono italic tracking-wide group-hover:text-text-main transition-colors">
                {post.data.description}
              </p>
              
              <div class="mt-auto flex items-center gap-3 text-tron-orange font-black text-[10px] uppercase tracking-[0.3em] group-hover:gap-6 transition-all">
                <span class="h-px w-6 bg-tron-orange/40 group-hover:w-10 transition-all"></span>
                Read Entry <span class="group-hover:translate-x-2 transition-transform">&rarr;</span>
              </div>
            </Link>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
