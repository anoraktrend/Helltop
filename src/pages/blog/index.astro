---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Link } from 'astro-link';

const blog = await getCollection('blog');

// Filter out drafts and sort posts by date (if available) or title
const validBlogPosts = blog.filter((post) => post.data.draft !== true);
const sortedPosts = validBlogPosts.sort((a, b) => {
  if (a.data.date && b.data.date) {
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  }
  return a.data.title.localeCompare(b.data.title);
});
---

<Layout title="Blog | Helltop">
  <section class="py-12">
    <h1 class="text-4xl font-bold text-ctp-mauve mb-12 uppercase tracking-widest">The Archive</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <article class="group flex flex-col bg-ctp-mantle border border-ctp-surface0 rounded-xl overflow-hidden hover:border-ctp-mauve transition-all hover:-translate-y-1 shadow-lg hover:shadow-ctp-mauve/10">
          <Link href={`/blog/${post.data.slug}`} class="flex flex-col h-full p-6">
            <div class="flex justify-between items-start mb-4">
              <div class="flex flex-wrap gap-2">
                {post.data.tags && post.data.tags.map((tag) => (
                  <span class="px-2 py-1 bg-ctp-surface0 text-ctp-mauve text-[10px] font-bold uppercase tracking-widest rounded border border-ctp-surface1">
                    {tag}
                  </span>
                ))}
              </div>
              {post.data.date && (
                <time class="text-ctp-subtext0 font-mono text-xs ml-auto">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              )}
            </div>
            
            <h2 class="text-xl font-bold text-ctp-text group-hover:text-ctp-mauve transition-colors mb-3 leading-tight">
              {post.data.title}
            </h2>
            
            <p class="text-ctp-subtext1 text-sm leading-relaxed mb-6 line-clamp-3">
              {post.data.description}
            </p>
            
            <div class="mt-auto flex items-center gap-2 text-ctp-pink font-bold text-xs uppercase tracking-tighter group-hover:gap-4 transition-all">
              Read Entry <span>&rarr;</span>
            </div>
          </Link>
        </article>
      ))}
    </div>
  </section>
</Layout>
