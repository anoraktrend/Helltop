---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blog = await getCollection('blog');

// Filter out drafts and sort posts by date (if available) or title
const validBlogPosts = blog.filter((post) => post.data.draft !== true);
const sortedPosts = validBlogPosts.sort((a, b) => {
  if (a.data.date && b.data.date) {
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  }
  return a.data.title.localeCompare(b.data.title);
});
<title>Blog | Helltop</title>
<Layout>
  <section class="py-12">
    <h1 class="text-4xl font-bold text-ctp-mauve mb-12 uppercase tracking-widest">The Archive</h1>
    
    <div class="flex flex-col gap-12">
      {sortedPosts.map((post) => (
        <article class="group">
          <a href={`/blog/${post.data.slug}`} class="block">
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-2">
              <h2 class="text-2xl font-bold text-ctp-text group-hover:text-ctp-mauve transition-colors">
                {post.data.title}
              </h2>
              {post.data.date && (
                <time class="text-ctp-subtext0 font-mono text-sm">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              )}
            </div>
            <p class="text-ctp-subtext1 leading-relaxed">
              {post.data.description}
            </p>
            <div class="mt-4 flex items-center gap-2 text-ctp-pink font-bold text-sm uppercase tracking-tighter group-hover:gap-4 transition-all">
              Read More <span>&rarr;</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
