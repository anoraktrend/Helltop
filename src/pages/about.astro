---
import Layout from '../layouts/Layout.astro';
import { getEntry, render as astroRender } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { Link } from 'astro-link';
import SystemStatus from '../components/SystemStatus.astro';

const author = await getEntry('authors', 'me');
if (!author) {
  throw new Error('Author "me" not found');
}

const { data } = author;
const { Content } = await astroRender(author);
---

<Layout title={`The Source | ${data.name} ${data.surname}`}>
  <div class="max-w-5xl mx-auto py-20 px-4">
    <!-- About Header -->
    <header class="mb-24 relative">
      <div class="flex flex-col sm:flex-row items-center gap-12 sm:gap-16">
        <div class="relative group">
          <div class="absolute -inset-4 bg-tron-blue/20 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition duration-1000"></div>
          <div class="identity-disc size-48 sm:size-64 border-[8px] shadow-[0_0_60px_var(--glow-blue-30)]">
            <img 
              src="/uploads/Author.png" 
              alt={data.name} 
              class="size-full object-cover rounded-full opacity-90 group-hover:scale-110 transition-transform duration-1000"
            />
          </div>
        </div>
        
        <div class="text-center sm:text-left space-y-6">
          <div class="flex items-center justify-center sm:justify-start gap-6 mb-4">
            <div class="size-4 bg-tron-blue rounded-full shadow-[0_0_15px_var(--glow-blue-100)] animate-pulse"></div>
            <h1 class="text-4xl sm:text-7xl font-black uppercase tracking-tighter tron-glow-text">
              {data.name} <span class="text-text-main">{data.surname}</span>
            </h1>
          </div>
          <p class="text-xl sm:text-2xl text-tron-blue font-mono uppercase tracking-[0.4em]">
            {data.role}
          </p>
          <p class="text-text-main text-sm font-mono uppercase tracking-[0.2em] opacity-80 max-w-xl">
            {data.sub_role}
          </p>
          <p class="text-text-dim text-lg leading-relaxed max-w-2xl font-light italic">
            "{data.short_bio}"
          </p>
        </div>
      </div>
    </header>

    <!-- Main Bio Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 mb-32">
      <div class="lg:col-span-2 space-y-16">
        <div class="relative group/bio">
          <div class="absolute -inset-8 bg-tron-blue/5 rounded-[3rem] blur-3xl -z-10"></div>
          <div class="prose prose-xl bg-ctp-mantle/30 p-10 rounded-3xl border border-tron-blue/10 shadow-[0_0_40px_var(--glow-blue-10)]">
            <Content />
          </div>
        </div>

        <!-- Manifesto -->
        <div class="relative group/manifesto">
          <div class="absolute -inset-8 bg-tron-orange/5 rounded-[3rem] blur-3xl -z-10"></div>
          <div class="p-10 rounded-3xl border border-tron-orange/20 bg-ctp-crust/50 shadow-[0_0_30px_var(--glow-orange-10)]">
            <h2 class="text-xs font-black text-tron-orange uppercase tracking-[0.6em] mb-10 flex items-center gap-3">
              <span class="size-2 bg-tron-orange rounded-full shadow-[0_0_10px_var(--glow-orange-100)] animate-pulse"></span>
              Core Directives
            </h2>
            <div class="grid sm:grid-cols-2 gap-8">
              {data.manifesto.map((item) => (
                <div class="flex items-start gap-4 group/item">
                  <div class="text-tron-orange font-mono text-lg opacity-40 group-hover/item:opacity-100 transition-opacity">
                    {item.split('.')[0]}.
                  </div>
                  <div class="text-text-main font-mono text-sm tracking-widest uppercase py-1 group-hover/item:text-tron-orange transition-colors">
                    {item.split('.').slice(1).join('.').trim()}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <aside class="space-y-12">
        <!-- Battlegrounds -->
        <div class="space-y-8">
          <div class="px-4 space-y-6">
            <h2 class="text-xs font-black text-text-overlay uppercase tracking-[0.5em] flex items-center gap-3">
              <span class="size-2 bg-tron-blue rounded-full shadow-[0_0_10px_var(--glow-blue-100)]"></span>
              Current Operations
            </h2>
            <SystemStatus />
          </div>
          <div class="space-y-4">
            {data.battlegrounds.map((bg) => (
              <div class="p-6 tron-card rounded-2xl border-tron-blue/10 hover:border-tron-blue/40 transition-all group/bg">
                <h3 class="text-tron-blue font-black uppercase text-[11px] tracking-widest mb-2 group-hover/bg:tron-glow-text transition-all">
                  {bg.title}
                </h3>
                <p class="text-text-dim text-xs leading-relaxed font-mono">
                  {bg.description}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Identity Links -->
        <div class="space-y-8">
          <h2 class="text-xs font-black text-text-overlay uppercase tracking-[0.5em] px-4 flex items-center gap-3">
            <span class="size-2 bg-tron-orange rounded-full shadow-[0_0_10px_var(--glow-orange-100)]"></span>
            Connection Protocols
          </h2>
          <div class="flex flex-col gap-3">
            {data.links.map((link) => {
              const isExternal = !link.url.startsWith('mailto:') && !link.url.startsWith('/') && !link.url.includes('helltop.net');
              const themeColor = isExternal ? 'tron-orange' : 'tron-blue';
              const glowVar = isExternal ? 'var(--glow-orange-50)' : 'var(--glow-blue-50)';
              return (
                <Link 
                  href={link.url} 
                  class={`p-5 tron-card border-${themeColor}/10 hover:border-${themeColor}/60 rounded-xl transition-all flex items-center gap-4 group/link`}
                >
                  <Icon name={link.icon} class={`size-5 text-${themeColor} group-hover/link:scale-110 transition-transform drop-shadow-[0_0_8px_${glowVar}]`} />
                  <span class={`text-[10px] font-mono uppercase tracking-widest text-text-overlay group-hover/link:text-${themeColor} transition-colors`}>
                    {link.name}
                  </span>
                </Link>
              );
            })}
          </div>
        </div>
      </aside>
    </div>

    <!-- CTA Section -->
    <div class="tron-card border-tron-blue/40 p-16 rounded-[4rem] text-center shadow-[0_0_80px_var(--glow-blue-10)] relative overflow-hidden group/cta">
      <div class="absolute inset-0 bg-gradient-to-br from-tron-blue/10 via-transparent to-tron-orange/10 opacity-50"></div>
      <div class="relative z-10 space-y-8">
        <h2 class="text-4xl sm:text-6xl font-black uppercase tracking-tighter text-text-main">
          {data.cta.title}
        </h2>
        <p class="text-xl text-text-muted font-light italic max-w-2xl mx-auto leading-relaxed">
          {data.cta.description}
        </p>
        <Link 
          href={`mailto:${data.cta.email}`}
          class="relative z-10 inline-block bg-tron-blue/10 hover:bg-tron-blue/20 text-tron-blue border border-tron-blue/40 hover:border-tron-blue font-black py-5 px-12 rounded-2xl transition-all uppercase tracking-[0.4em] text-sm shadow-[0_0_30px_var(--glow-blue-20)] hover:shadow-[0_0_50px_var(--glow-blue-40)] active:scale-95"
        >
          {data.cta.button_text}
        </Link>
      </div>
    </div>
  </div>
</Layout>
