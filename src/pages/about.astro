---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { Link } from 'astro-link';

const author = await getEntry('authors', 'me');

if (!author) {
  throw new Error('Author "me" not found in "authors" collection');
}

const { data } = author;
const { Content } = await render(author);
---

<Layout title={`About | ${data.surname}`} description={data.short_bio}>
  <div class="py-12 max-w-5xl mx-auto space-y-32">
    <!-- Header Section -->
    <header class="relative group">
      <div class="absolute -top-12 -right-12 size-64 bg-tron-blue/5 rounded-full blur-3xl -z-10 animate-pulse"></div>
      <div class="flex items-center gap-6 mb-10">
        <div class="size-4 bg-tron-blue rounded-full shadow-[0_0_15px_rgba(203,166,247,1)]"></div>
        <h1 class="text-6xl sm:text-8xl font-black text-text-main tracking-tighter uppercase tron-glow-text">
          {data.name} <span class="text-tron-orange italic">{data.surname}</span>
        </h1>
      </div>
      <p class="text-2xl sm:text-3xl text-text-muted leading-relaxed font-light italic font-mono border-l-4 border-tron-blue/30 pl-8">
        {data.role} // {data.sub_role}
      </p>
    </header>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-20">
      <!-- Left Column: Biography -->
      <div class="lg:col-span-2 space-y-24">
        <section class="relative">
          <div class="flex items-center gap-6 mb-12">
            <h2 class="text-2xl font-black text-text-main uppercase tracking-[0.4em] tron-glow-text">
              Mission Brief
            </h2>
            <div class="h-px flex-grow bg-tron-blue/20"></div>
          </div>
          <div class="prose prose-xl bg-ctp-mantle/30 p-10 rounded-3xl border border-tron-blue/10 shadow-[0_0_40px_rgba(0,0,0,0.2)]">
            <Content />
          </div>
        </section>

        <section>
          <div class="flex items-center gap-6 mb-12">
            <h2 class="text-2xl font-black text-text-main uppercase tracking-[0.4em] tron-glow-text">
              Battlegrounds
            </h2>
            <div class="h-px flex-grow bg-tron-blue/20"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            {data.battlegrounds.map((bg) => (
              <div class="tron-card p-8 rounded-2xl border-tron-blue/10 hover:border-tron-orange/40 transition-all duration-500 group/bg">
                <h3 class="text-tron-orange font-black mb-4 uppercase tracking-[0.2em] group-hover/bg:tron-orange-glow-text transition-all">{bg.title}</h3>
                <p class="text-text-muted text-sm font-mono leading-relaxed italic">{bg.description}</p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- Right Column: Stats/Sidebar -->
      <aside class="space-y-16">
        <div class="p-10 tron-card rounded-3xl border-tron-blue/15 shadow-2xl relative overflow-hidden">
          <div class="absolute top-0 right-0 size-32 bg-tron-blue/5 rounded-full blur-2xl"></div>
          <h2 class="text-xs font-black text-text-main uppercase tracking-[0.5em] mb-10 pb-4 border-b border-tron-blue/10">Manifesto</h2>
          <ul class="space-y-6 text-xs font-mono text-text-muted">
            {data.manifesto.map((item) => (
              <li class="flex gap-4 group/man">
                <span class="text-tron-blue font-black group-hover/man:tron-glow-text transition-all uppercase">{item.slice(0, 3)}</span>
                <span class="group-hover/man:text-text-main transition-colors leading-relaxed">{item.slice(4)}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-8">
          <h2 class="text-xs font-black text-text-dim uppercase tracking-[0.5em] px-4">Encrypted Comms</h2>
          <div class="flex flex-col gap-4">
            {data.links.map((link) => {
              const isExternal = !link.url.startsWith('mailto:') && !link.url.startsWith('/') && !link.url.includes('helltop.net');
              const themeColor = isExternal ? 'tron-orange' : 'tron-blue';
              const glowColor = isExternal ? 'rgba(245,194,231,0.5)' : 'rgba(203,166,247,0.5)';
              return (
                <Link 
                  href={link.url} 
                  aria-label={`Connect via ${link.name}`}
                  class={`p-5 tron-card hover:bg-${themeColor}/5 border-${themeColor}/10 hover:border-${themeColor}/60 rounded-2xl transition-all flex items-center gap-5 group/link`}
                >
                  <Icon name={link.icon} class={`size-5 text-${themeColor} group-hover/link:scale-110 transition-all drop-shadow-[0_0_8px_${glowColor}]`} />
                  <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-text-overlay group-hover/link:text-text-main transition-colors">{link.name}</span>
                </Link>
              );
            })}
          </div>
        </div>
      </aside>
    </div>

    <!-- Bottom CTA -->
    <div class="tron-card border-tron-blue/40 p-16 rounded-[4rem] text-center shadow-[0_0_80px_rgba(203,166,247,0.1)] relative overflow-hidden group/cta">
      <div class="absolute inset-0 bg-gradient-to-br from-tron-blue/10 to-tron-orange/5"></div>
      <h2 class="text-3xl font-black text-text-main mb-6 tracking-tight italic uppercase tron-glow-text relative z-10">{data.cta.title}</h2>
      <p class="text-text-muted mb-12 max-w-2xl mx-auto text-lg leading-relaxed relative z-10 font-mono italic">
        {data.cta.description}
      </p>
      <Link 
        href={`mailto:${data.cta.email}`} 
        class="relative z-10 inline-block bg-tron-blue/10 hover:bg-tron-blue/20 text-tron-blue border border-tron-blue/40 hover:border-tron-blue font-black py-5 px-12 rounded-2xl transition-all uppercase tracking-[0.4em] text-sm shadow-[0_0_30px_rgba(203,166,247,0.2)] hover:shadow-[0_0_50px_rgba(203,166,247,0.4)] active:scale-95"
      >
        {data.cta.button_text}
      </Link>
    </div>
  </div>
</Layout>
