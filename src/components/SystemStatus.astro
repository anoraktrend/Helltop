---
import StatusBadge from './StatusBadge.astro';
import { Link } from 'astro-link';

let stats = { up: 0, total: 0 };
let error = false;

try {
  const res = await fetch('https://status.helltop.net/api/status');
  if (res.ok) {
    const data = await res.json();
    stats.total = data.services.length;
    stats.up = data.services.filter((s: any) => s.latest?.status === 'up').length;
  } else {
    error = true;
  }
} catch (e) {
  console.error('Failed to fetch status stats', e);
  error = true;
}

const isAllUp = stats.up === stats.total && stats.total > 0;
const isPartiallyDown = stats.up < stats.total && stats.up > 0;
---

<Link 
  href="https://status.helltop.net" 
  class="inline-flex items-center gap-4 px-5 py-2.5 bg-ctp-mantle border border-ctp-surface0 rounded-full hover:border-ctp-mauve hover:shadow-lg hover:shadow-ctp-mauve/5 transition-all group"
>
  <div class="relative flex items-center justify-center">
    <StatusBadge name="all" class="size-5" />
    {!error && stats.total > 0 && (
      <div class:list={[
        "absolute inset-0 rounded-full animate-ping opacity-40",
        isAllUp ? "bg-green-500" : "bg-red-500"
      ]}></div>
    )}
  </div>
  
  <div class="flex flex-col items-start leading-tight">
    <span class="text-[9px] font-black text-ctp-overlay1 uppercase tracking-[0.25em]">Network Status</span>
    <span class="text-xs font-bold text-ctp-subtext1 group-hover:text-ctp-mauve transition-colors uppercase tracking-widest mt-0.5">
      {error ? (
        "Status Offline"
      ) : stats.total === 0 ? (
        "No Services Tracked"
      ) : isAllUp ? (
        "All Systems Go"
      ) : isPartiallyDown ? (
        <span class="text-ctp-yellow">{stats.total - stats.up} Nodes Critical</span>
      ) : (
        <span class="text-ctp-red">Total Outage</span>
      )}
    </span>
  </div>

  <div class="h-4 w-px bg-ctp-surface1 mx-1"></div>
  
  <div class="flex items-center gap-1.5">
    <span class="text-[10px] font-mono text-ctp-mauve">{stats.up}/{stats.total}</span>
    <span class="text-[8px] font-bold text-ctp-overlay0 uppercase tracking-tighter">Online</span>
  </div>
</Link>
