---
interface Props {
  status: string;
  class?: string;
}

const { status, class: className } = Astro.props;
const statusUrl = `https://status.helltop.net/badges/${encodeURIComponent(status)}.svg`;
---

<div class:list={["relative flex items-center justify-center", className]}>
  <img 
    src={statusUrl} 
    alt={`${status} status`} 
    class="w-full h-full object-contain"
    loading="lazy"
  />
</div>
