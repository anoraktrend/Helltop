<div class="starfield-container" id="starfield-container">
  <canvas id="starfield"></canvas>
</div>

<style>
  .starfield-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    background: #1e1e2e;
  }
  
  #starfield {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 1;
  }
</style>

<script>
  function isWebGLSupported() {
    try {
      const canvas = document.createElement('canvas');
      return !!(window.WebGLRenderingContext && (canvas.getContext('webgl') || canvas.getContext('experimental-webgl')));
    } catch (e) {
      return false;
    }
  }

  let targetMouseX = 0;
  let targetMouseY = 0;
  let targetScrollY = 0;
  let currentMouseX = 0;
  let currentMouseY = 0;
  let currentScrollY = 0;
  let currentMode = 0.0; // 0: Mocha, 1: Frappe, 2: Macchiato, 3: Latte

  function handleMouseMove(e: MouseEvent) {
    targetMouseX = (e.clientX / window.innerWidth) * 2 - 1;
    targetMouseY = (e.clientY / window.innerHeight) * 2 - 1;
  }

  function handleScroll() {
    targetScrollY = window.scrollY;
  }

  function updateThemeMode() {
    const classes = document.documentElement.classList;
    if (classes.contains('frappe')) currentMode = 1.0;
    else if (classes.contains('macchiato')) currentMode = 2.0;
    else if (classes.contains('latte')) currentMode = 3.0;
    else currentMode = 0.0; // Default to Mocha
  }

  if (typeof window !== 'undefined') {
    window.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('scroll', handleScroll);
    targetScrollY = currentScrollY = window.scrollY;
    updateThemeMode();

    const observer = new MutationObserver(updateThemeMode);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  function initStarfield() {
    if (!isWebGLSupported()) return;

    const canvas = document.getElementById('starfield') as HTMLCanvasElement;
    if (!canvas) return;

    const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl') as WebGLRenderingContext;
    if (!gl) return;

    const vsSource = `
      attribute vec4 aVertexPosition;
      void main() {
        gl_Position = aVertexPosition;
      }
    `;

    const fsSource = `
      precision highp float;
      uniform vec2 uResolution;
      uniform float uTime;
      uniform vec2 uMouse;
      uniform float uScroll;
      uniform float uMode;

      // Color Palettes
      const vec3 MOCHA_BASE = vec3(0.117, 0.117, 0.180);
      
      const vec3 FRAPPE_BASE = vec3(0.188, 0.204, 0.275);
      const vec3 FRAPPE_SURFACE = vec3(0.255, 0.271, 0.349);
      const vec3 FRAPPE_MAUVE = vec3(0.792, 0.620, 0.902);
      const vec3 FRAPPE_LAVENDER = vec3(0.729, 0.733, 0.945);

      const vec3 MACCHIATO_BASE = vec3(0.141, 0.153, 0.227);
      const vec3 MACCHIATO_SURFACE = vec3(0.212, 0.227, 0.310);
      const vec3 MACCHIATO_MAUVE = vec3(0.776, 0.627, 0.965);
      const vec3 MACCHIATO_PEACH = vec3(0.961, 0.663, 0.498);

      const vec3 LATTE_BASE = vec3(0.937, 0.945, 0.961);
      const vec3 LATTE_SURFACE = vec3(0.800, 0.816, 0.855);
      const vec3 LATTE_MAUVE = vec3(0.533, 0.224, 0.937);
      const vec3 LATTE_SKY = vec3(0.016, 0.647, 0.898);

      // Noise functions
      float random(vec2 st) {
        return fract(sin(dot(st.xy, vec2(12.9898, 78.233))) * 43758.5453123);
      }

      float noise(vec2 st) {
        vec2 i = floor(st);
        vec2 f = fract(st);
        float a = random(i);
        float b = random(i + vec2(1.0, 0.0));
        float c = random(i + vec2(0.0, 1.0));
        float d = random(i + vec2(1.0, 1.0));
        vec2 u = f * f * (3.0 - 2.0 * f);
        return mix(a, b, u.x) + (c - a) * u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
      }

      #define OCTAVES 6
      float fbm(vec2 st) {
        float value = 0.0;
        float amplitude = 0.5;
        for (int i = 0; i < OCTAVES; i++) {
          value += amplitude * noise(st);
          st *= 2.0;
          amplitude *= 0.5;
        }
        return value;
      }

      float hash(vec2 p) {
        p = fract(p * vec2(123.34, 456.21));
        p += dot(p, p + 45.32);
        return fract(p.x * p.y);
      }

      // 0: Mocha - Cosmic Starfield
      vec3 renderMocha(vec2 uv, vec2 mouseEffect, float scrollEffect) {
        vec3 color = MOCHA_BASE;
        vec2 st1 = uv * 2.0 + mouseEffect * 0.5 + vec2(0.0, scrollEffect * 0.4) + vec2(uTime * 0.04, uTime * 0.02);
        vec2 ipos1 = floor(st1 * 20.0);
        vec2 fpos1 = fract(st1 * 20.0);
        float h1 = hash(ipos1);
        if (h1 > 0.98) color += vec3(0.8, 0.7, 1.0) * (1.0 - smoothstep(0.0, 0.1 * h1, distance(fpos1, vec2(0.5))));

        vec2 st2 = uv * 4.0 + mouseEffect + vec2(0.0, scrollEffect * 0.8) + vec2(-uTime * 0.02, uTime * 0.01);
        vec2 ipos2 = floor(st2 * 15.0);
        vec2 fpos2 = fract(st2 * 15.0);
        float h2 = hash(ipos2);
        if (h2 > 0.99) color += vec3(1.0, 0.8, 0.9) * (1.0 - smoothstep(0.0, 0.05, distance(fpos2, vec2(0.5))));
        return color;
      }

      // 1: Frappe - Drifting Clouds
      vec3 renderFrappe(vec2 uv, vec2 mouseEffect, float scrollEffect) {
        vec2 st = uv * 3.0;
        vec2 q = vec2(fbm(st + 0.1 * uTime + mouseEffect), fbm(st + vec2(1.0) + scrollEffect));
        vec2 r = vec2(fbm(st + 1.0 * q + vec2(1.7, 9.2) + 0.15 * uTime + mouseEffect * 0.5), 
                      fbm(st + 1.0 * q + vec2(8.3, 2.8) + 0.126 * uTime + scrollEffect * 0.5));
        float f = fbm(st + r);
        vec3 color = mix(FRAPPE_BASE, FRAPPE_SURFACE, clamp((f * f) * 4.0, 0.0, 1.0));
        color = mix(color, FRAPPE_MAUVE, clamp(length(q), 0.0, 1.0) * 0.2);
        color = mix(color, FRAPPE_LAVENDER, clamp(length(r.x), 0.0, 1.0) * 0.1);
        return color * (f * f * f + 0.6 * f * f + 0.5 * f);
      }

      // 2: Macchiato - Fluid Swirls
      vec3 renderMacchiato(vec2 uv, vec2 mouseEffect, float scrollEffect) {
        vec2 st = uv * 2.0;
        for(int n = 1; n < 4; n++){
          float i = float(n);
          st += vec2(0.7 / i * sin(i * st.y + uTime + 0.3 * i) + 0.8 + mouseEffect.x, 
                     0.4 / i * sin(i * st.x + uTime + 0.3 * i) + 1.6 + scrollEffect);
        }
        vec3 color = mix(MACCHIATO_BASE, MACCHIATO_SURFACE, 0.5 + 0.5 * sin(st.x + st.y));
        color = mix(color, MACCHIATO_MAUVE, 0.3 * sin(uTime * 0.5));
        color = mix(color, MACCHIATO_PEACH, 0.2 * cos(st.y + uTime));
        return color;
      }

      // 3: Latte - Ethereal Light
      vec3 renderLatte(vec2 uv, vec2 mouseEffect, float scrollEffect) {
        float f = fbm(uv * 1.5 + uTime * 0.05 + mouseEffect * 0.2 + vec2(0.0, scrollEffect * 0.1));
        vec3 color = mix(LATTE_BASE, LATTE_SURFACE, f);
        color = mix(color, LATTE_MAUVE, 0.15 * fbm(uv * 2.0 - uTime * 0.02));
        color = mix(color, LATTE_SKY, 0.1 * fbm(uv * 3.0 + uTime * 0.03));
        return color;
      }

      void main() {
        vec2 uv = (gl_FragCoord.xy - 0.5 * uResolution.xy) / min(uResolution.y, uResolution.x);
        vec2 mouseEffect = uMouse * 0.1;
        float scrollEffect = uScroll * 0.0005;

        vec3 color;
        if (uMode < 0.5) color = renderMocha(uv, mouseEffect, scrollEffect);
        else if (uMode < 1.5) color = renderFrappe(uv, mouseEffect, scrollEffect);
        else if (uMode < 2.5) color = renderMacchiato(uv, mouseEffect, scrollEffect);
        else color = renderLatte(uv, mouseEffect, scrollEffect);

        gl_FragColor = vec4(color, 1.0);
      }
    `;

    function createShader(gl: WebGLRenderingContext, type: number, source: string) {
      const shader = gl.createShader(type);
      if (!shader) return null;
      gl.shaderSource(shader, source);
      gl.compileShader(shader);
      if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
        console.error(gl.getShaderInfoLog(shader));
        gl.deleteShader(shader);
        return null;
      }
      return shader;
    }

    const vertexShader = createShader(gl, gl.VERTEX_SHADER, vsSource);
    const fragmentShader = createShader(gl, gl.FRAGMENT_SHADER, fsSource);
    if (!vertexShader || !fragmentShader) return;

    const program = gl.createProgram();
    if (!program) return;
    gl.attachShader(program, vertexShader);
    gl.attachShader(program, fragmentShader);
    gl.linkProgram(program);
    if (!gl.getProgramParameter(program, gl.LINK_STATUS)) return;

    const positionAttributeLocation = gl.getAttribLocation(program, "aVertexPosition");
    const resolutionUniformLocation = gl.getUniformLocation(program, "uResolution");
    const timeUniformLocation = gl.getUniformLocation(program, "uTime");
    const mouseUniformLocation = gl.getUniformLocation(program, "uMouse");
    const scrollUniformLocation = gl.getUniformLocation(program, "uScroll");
    const modeUniformLocation = gl.getUniformLocation(program, "uMode");

    const positionBuffer = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, positionBuffer);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,1, 1,1, -1,-1, 1,-1]), gl.STATIC_DRAW);

    function resize() {
      if (!canvas) return;
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      gl!.viewport(0, 0, canvas.width, canvas.height);
    }

    window.addEventListener('resize', resize);
    resize();

    function render(time: number) {
      currentMouseX += (targetMouseX - currentMouseX) * 0.05;
      currentMouseY += (targetMouseY - currentMouseY) * 0.05;
      currentScrollY += (targetScrollY - currentScrollY) * 0.05;

      gl!.clearColor(0, 0, 0, 0);
      gl!.clear(gl!.COLOR_BUFFER_BIT);
      gl!.useProgram(program);
      gl!.enableVertexAttribArray(positionAttributeLocation);
      gl!.bindBuffer(gl!.ARRAY_BUFFER, positionBuffer);
      gl!.vertexAttribPointer(positionAttributeLocation, 2, gl!.FLOAT, false, 0, 0);

      gl!.uniform2f(resolutionUniformLocation, canvas.width, canvas.height);
      gl!.uniform1f(timeUniformLocation, time * 0.001);
      gl!.uniform2f(mouseUniformLocation, currentMouseX, currentMouseY);
      gl!.uniform1f(scrollUniformLocation, currentScrollY);
      gl!.uniform1f(modeUniformLocation, currentMode);

      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
      requestAnimationFrame(render);
    }
    requestAnimationFrame(render);
  }

  initStarfield();
  document.addEventListener('astro:after-swap', initStarfield);
</script>


