---
import { Icon } from 'astro-icon/components';
import RecursiveCommentItem from './CommentItem.astro';

interface Props {
  comment: any;
  depth?: number;
}

const { comment, depth = 0 } = Astro.props;
---

<div class={`space-y-4 sm:space-y-6 ${depth > 0 ? 'ml-4 sm:ml-12 border-l border-tron-blue/10 pl-4 sm:pl-10 mt-4 sm:mt-6' : ''}`}>
  <div class="tron-card p-4 sm:p-8 rounded-xl sm:rounded-2xl border-tron-blue/10 hover:border-tron-blue/30 transition-all duration-500 relative group/comment">
    {/* Connection line for replies */}
    {depth > 0 && (
      <div class="absolute -left-[calc(1rem+1px)] sm:-left-[calc(2.5rem+1px)] top-10 w-4 sm:w-10 h-px bg-tron-blue/10"></div>
    )}

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4 sm:mb-6 border-b border-tron-blue/5 pb-4">
      <div class="flex items-center gap-3">
        <div class="size-1.5 sm:size-2 bg-tron-blue rounded-full shadow-[0_0_8px_var(--glow-blue-80)]"></div>
        <span class="text-tron-blue text-[10px] sm:text-[11px] font-black uppercase tracking-[0.2em] sm:tracking-[0.3em]">
          {comment.author}
        </span>
        <span class="text-[8px] sm:text-[9px] text-text-dim font-mono opacity-40">#{comment.id}</span>
      </div>
      <div class="flex items-center gap-4 sm:gap-6 w-full sm:w-auto justify-between sm:justify-end">
        <span class="text-text-overlay text-[8px] sm:text-[9px] font-mono uppercase tracking-widest">
          {new Date(comment.publishedAt).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })}
        </span>
        <button 
          @click={`setReply(${comment.id})`}
          class="text-[9px] sm:text-[10px] font-black text-tron-blue hover:text-text-main uppercase tracking-[0.2em] transition-colors flex items-center gap-2 group/reply-btn"
        >
          <Icon name="lucide:reply" class="size-2.5 sm:size-3 group-hover/reply-btn:-translate-x-1 transition-transform" />
          Reply
        </button>
      </div>
    </div>
    <p class="text-text-muted font-mono leading-relaxed text-xs sm:text-sm tracking-wide">{comment.body}</p>
  </div>

  {comment.replies && comment.replies.length > 0 && (
    <div class="space-y-4 sm:space-y-6">
      {comment.replies.map((reply: any) => (
        <RecursiveCommentItem comment={reply} depth={depth + 1} />
      ))}
    </div>
  )}
</div>
