---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.svelte';
import SocialLinks from '../components/SocialLinks.astro';
import { Icon } from 'astro-icon/components';
import StatusBadge from '../components/StatusBadge.astro';
import { Link } from 'astro-link';
import Starfield from '../components/Starfield.astro';

interface Props {
	title: string;
  description?: string;
}

const { title, description = "My Digital Rebellion. Fuck the corporate cloud. Build your own." } = Astro.props;
---

<!doctype html>
<html lang="en" class="mocha antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" sizes="650x650" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook / LinkedIn -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/opengraph-image.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="/opengraph-image.png" />

		<!-- Security & Performance -->
		<meta name="theme-color" content="#1e1e2e" media="(prefers-color-scheme: dark)" />
		<meta name="color-scheme" content="light dark" />
		<noscript>
			<style>html{scroll-behavior:auto}</style>
		</noscript>

		<!-- Preconnect & DNS prefetch -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://status.helltop.net" />
		<link rel="dns-prefetch" href="https://liberapay.com">

<script is:inline>
	  // Prevent FOUT/FIT for theme switch
	  const flavor = localStorage.getItem('catppuccin-flavor') || 'mocha';
	  document.documentElement.classList.add(flavor);
	</script>

	<!-- Structured Data for Search Engines -->
	<script type="application/ld+json">{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"url": "${Astro.url.origin}",
		"name": "Helltop"
	}</script>

	<script type="application/ld+json">{
		"@context": "https://schema.org",
		"@type": "Blog",
		"url": "${Astro.url.pathname.startsWith('/blog') ? Astro.url.origin + '/blog' : Astro.url.origin}",
		"name": "${title}"
	}</script>

</head>
	<body class="min-h-screen flex flex-col font-sans" aria-label={`Helltop - ${title}`} x-data="{ mobileMenuOpen: false }">
		<Starfield />
<nav aria-label="Main navigation" class="sticky top-0 z-40 w-full backdrop-blur flex-none transition-colors duration-500 bg-ctp-base/80 border-b border-ctp-surface0">
	  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
	    <div class="flex justify-between h-16 items-center">
	      <div class="flex items-center gap-4 sm:gap-8 text-ctp-overlay2">
		<Link href="/" class="text-xl font-bold text-ctp-mauve hover:text-ctp-pink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ctp-pink rounded" aria-label="Home">
		  Helltop
		</Link>
		<div class="hidden sm:flex gap-6">
		  <Link href="/blog" class="hover:text-ctp-text transition-colors uppercase text-sm font-bold tracking-widest focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ctp-mauve rounded px-2 py-1" aria-label="Blog">
			Blog
		  </Link>
		  <Link href="/about" class="hover:text-ctp-text transition-colors uppercase text-sm font-bold tracking-widest focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ctp-mauve rounded px-2 py-1" aria-label="About">
			About
		  </Link>
		</div>
	      </div>
	      <div class="flex items-center gap-3 sm:gap-6 text-ctp-overlay2">
		<SocialLinks iconSize="5" spacing="4" class="hidden lg:flex" />
		<div class="h-6 w-px bg-ctp-surface0 hidden md:block"></div>
		<ThemeSwitcher client:load aria-label="Toggle dark mode" />
                
                <!-- Mobile Menu Button -->
                <button 
                  @click="mobileMenuOpen = !mobileMenuOpen" 
                  class="sm:hidden p-2 text-ctp-mauve hover:bg-ctp-surface0 rounded-lg transition-colors focus:outline-none"
                  aria-label="Toggle mobile menu"
                >
                  <Icon name="lucide:menu" x-show="!mobileMenuOpen" class="size-6" />
                  <Icon name="lucide:x" x-show="mobileMenuOpen" class="size-6" style="display: none;" />
                </button>
	      </div>
	    </div>
	  </div>

          <!-- Mobile Menu Overlay -->
          <div 
            x-show="mobileMenuOpen" 
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-4"
            class="sm:hidden bg-ctp-mantle border-b border-ctp-surface0"
            style="display: none;"
          >
            <div class="px-4 pt-2 pb-6 space-y-1">
              <Link href="/blog" class="block px-3 py-4 text-base font-bold text-ctp-text hover:text-ctp-mauve hover:bg-ctp-surface0 rounded-lg transition-all uppercase tracking-widest">
                Blog
              </Link>
              <Link href="/about" class="block px-3 py-4 text-base font-bold text-ctp-text hover:text-ctp-mauve hover:bg-ctp-surface0 rounded-lg transition-all uppercase tracking-widest">
                About
              </Link>
              <div class="pt-4 mt-4 border-t border-ctp-surface0">
                <p class="px-3 text-xs font-black text-ctp-overlay1 uppercase tracking-widest mb-4">Social Transmissions</p>
                <SocialLinks iconSize="6" spacing="6" class="px-3" />
              </div>
            </div>
          </div>
	</nav>

    <main class="flex-grow max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
      <slot />
    </main>

    <footer class="bg-ctp-crust border-t border-ctp-surface0 py-12 text-center mt-24 text-ctp-overlay2">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
        <p>&copy; {new Date().getFullYear()} helltop.net</p>
        
        <div class="flex justify-center items-center gap-6">
          <SocialLinks iconSize="5" spacing="6" />
          <div class="h-4 w-px bg-ctp-surface0"></div>
          <Link href="/rss.xml" class="hover:text-ctp-mauve transition-colors" title="RSS Feed">
            <Icon name="lucide:rss" class="size-5" />
          </Link>
          <div class="h-4 w-px bg-ctp-surface0"></div>
          <Link href="https://status.helltop.net" class="flex items-center gap-2 hover:text-ctp-mauve transition-colors text-xs font-bold uppercase tracking-widest" title="System Status">
            <StatusBadge name="all" class="size-4" />
            Status
          </Link>
        </div>
      </div>
    </footer>
	</body>
</html>
