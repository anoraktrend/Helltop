---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.svelte';
import SocialLinks from '../components/SocialLinks.astro';
import { Icon } from 'astro-icon/components';
import StatusBadge from '../components/StatusBadge.astro';
import { Link } from 'astro-link';
import Starfield from '../components/Starfield.astro';

interface Props {
	title: string;
  description?: string | undefined;
}

const { title, description = "My Digital Rebellion. Fuck the corporate cloud. Build your own." } = Astro.props;
---

<!doctype html>
<html lang="en" class="mocha antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" sizes="650x650" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook / LinkedIn -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/opengraph-image.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="/opengraph-image.png" />

		<!-- Security & Performance -->
		<meta name="theme-color" content="#1e1e2e" media="(prefers-color-scheme: dark)" />
		<meta name="color-scheme" content="light dark" />
		<noscript>
			<style>html{scroll-behavior:auto}</style>
		</noscript>

		<!-- Preconnect & DNS prefetch -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://status.helltop.net" />
		<link rel="dns-prefetch" href="https://liberapay.com">

<script is:inline>
	  // Prevent FOUT/FIT for theme switch
	  const flavor = localStorage.getItem('catppuccin-flavor') || 'mocha';
	  document.documentElement.classList.add(flavor);
	</script>

	<!-- Structured Data for Search Engines -->
	<script type="application/ld+json" is:inline set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "WebSite",
		"url": Astro.url.origin,
		"name": "Helltop"
	})} />

	<script type="application/ld+json" is:inline set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Blog",
		"url": Astro.url.pathname.startsWith('/blog') ? Astro.url.origin + '/blog' : Astro.url.origin,
		"name": title
	})} />

</head>
	<body class="min-h-screen flex flex-col font-sans selection:bg-ctp-surface2 selection:text-text-main overflow-x-hidden" aria-label={`Helltop - ${title}`} x-data="{ mobileMenuOpen: false, scrolled: false }" @scroll.window="scrolled = window.pageYOffset > 20">
		<Starfield />
<nav aria-label="Main navigation" 
  class="sticky top-0 z-40 w-full transition-all duration-500 border-b"
  :class="scrolled ? 'bg-ctp-base/80 backdrop-blur-xl border-tron-blue/40 shadow-[0_0_30px_var(--glow-blue-15)] py-2' : 'bg-transparent border-transparent py-4'"
>
	  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
	    <div class="flex justify-between h-16 items-center">
	      <div class="flex items-center gap-4 sm:gap-12">
		<div class="hidden sm:flex items-center bg-ctp-crust/40 rounded-xl p-1 border border-tron-blue/10">
		  <Link 
        href="/" 
        class={`px-6 py-2 rounded-lg transition-all uppercase text-sm font-black tracking-widest relative group/nav ${Astro.url.pathname === '/' ? 'bg-tron-blue/20 text-tron-blue shadow-[0_0_15px_var(--glow-blue-20)] border border-tron-blue/30' : 'text-text-overlay hover:text-text-main hover:bg-white/5'}`} 
        aria-label="Home"
      >
			  Helltop
        {Astro.url.pathname === '/' && (
          <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-tron-blue shadow-[0_0_10px_var(--glow-blue-100)]"></span>
        )}
		  </Link>
		  <Link 
        href="/blog" 
        class={`px-6 py-2 rounded-lg transition-all uppercase text-sm font-black tracking-widest relative group/nav ${Astro.url.pathname.startsWith('/blog') ? 'bg-tron-blue/20 text-tron-blue shadow-[0_0_15px_var(--glow-blue-20)] border border-tron-blue/30' : 'text-text-overlay hover:text-text-main hover:bg-white/5'}`} 
        aria-label="Blog"
      >
			  Blog
        {Astro.url.pathname.startsWith('/blog') && (
          <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-tron-blue shadow-[0_0_10px_var(--glow-blue-100)]"></span>
        )}
		  </Link>
		  <Link 
        href="/about" 
        class={`px-6 py-2 rounded-lg transition-all uppercase text-sm font-black tracking-widest relative group/nav ${Astro.url.pathname.startsWith('/about') ? 'bg-tron-blue/20 text-tron-blue shadow-[0_0_15px_var(--glow-blue-20)] border border-tron-blue/30' : 'text-text-overlay hover:text-text-main hover:bg-white/5'}`} 
        aria-label="About"
      >
			  About
        {Astro.url.pathname.startsWith('/about') && (
          <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-tron-blue shadow-[0_0_10px_var(--glow-blue-100)]"></span>
        )}
		  </Link>
		</div>
	      </div>
	      <div class="flex items-center gap-3 sm:gap-6">
		<SocialLinks iconSize="5" spacing="6" class="hidden lg:flex" />
		<div class="h-6 w-px bg-tron-blue/20 hidden md:block"></div>
		<ThemeSwitcher client:load aria-label="Toggle dark mode" />
                
                <!-- Mobile Menu Button -->
                <button 
                  @click="mobileMenuOpen = !mobileMenuOpen" 
                  class="sm:hidden p-3 text-tron-blue hover:bg-tron-blue/10 rounded-xl transition-all border border-tron-blue/20 active:scale-90"
                  aria-label="Toggle mobile menu"
                >
                  <Icon name="lucide:menu" x-show="!mobileMenuOpen" class="size-6" />
                  <Icon name="lucide:x" x-show="mobileMenuOpen" class="size-6" style="display: none;" />
                </button>
	      </div>
	    </div>
	  </div>

          <!-- Mobile Menu Overlay -->
          <div 
            x-show="mobileMenuOpen" 
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 -translate-y-10"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-10"
            class="sm:hidden bg-ctp-crust/98 backdrop-blur-3xl border-b border-tron-blue/40 shadow-[0_20px_50px_var(--glow-blue-20)]"
            style="display: none;"
          >
            <div class="px-6 pt-4 pb-10 space-y-2">
              <Link href="/blog" class="block px-4 py-5 text-lg font-black text-text-main hover:text-tron-blue hover:bg-tron-blue/5 rounded-2xl transition-all uppercase tracking-[0.2em] border border-transparent hover:border-tron-blue/20">
                &gt; Blog
              </Link>
              <Link href="/about" class="block px-4 py-5 text-lg font-black text-text-main hover:text-tron-blue hover:bg-tron-blue/5 rounded-2xl transition-all uppercase tracking-[0.2em] border border-transparent hover:border-tron-blue/20">
                &gt; About
              </Link>
              <div class="pt-8 mt-6 border-t border-tron-blue/20">
                <p class="px-4 text-[10px] font-black text-text-overlay uppercase tracking-[0.5em] mb-6">Grid Identity</p>
                <SocialLinks iconSize="6" spacing="8" class="px-4" />
              </div>
            </div>
          </div>
	</nav>

    <main class="flex-grow max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
      <slot />
    </main>

    <footer class="bg-ctp-crust/90 backdrop-blur-xl border-t border-tron-blue/20 py-16 text-center mt-32 relative overflow-hidden">
      <!-- Footer Grid Glow -->
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-px bg-tron-blue shadow-[0_0_30px_2px_var(--glow-blue-80)]"></div>
      
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10 relative z-10">
        <div class="flex flex-col items-center gap-4">
          <div class="text-[11px] font-mono uppercase tracking-[0.8em] text-text-dim mb-2">End of Line</div>
          <p class="text-[12px] font-mono uppercase tracking-[0.6em] text-text-muted">
            &copy; {new Date().getFullYear()} <span class="text-tron-blue tron-glow-text">helltop.net</span>
          </p>
        </div>
        
        <div class="flex justify-center items-center gap-10">
          <SocialLinks iconSize="5" spacing="10" />
          <div class="h-6 w-px bg-tron-blue/20"></div>
          <Link 
            href="/rss.xml" 
            class="text-text-dim hover:text-tron-blue transition-all hover:scale-125 hover:drop-shadow-[0_0_8px_var(--glow-blue-60)]" 
            title="RSS Feed"
            aria-label="RSS Feed"
          >
            <Icon name="lucide:rss" class="size-5" />
          </Link>
          <div class="h-6 w-px bg-tron-blue/20"></div>
          <Link href="https://status.helltop.net" class="flex items-center gap-4 text-text-dim hover:text-tron-orange transition-all hover:scale-105 text-[10px] font-black uppercase tracking-[0.4em] group" title="System Status">
            <StatusBadge name="all" class="size-3" />
            <span class="group-hover:text-tron-orange transition-colors drop-shadow-[0_0_8px_var(--glow-orange-10)] group-hover:drop-shadow-[0_0_12px_var(--glow-orange-50)]">System Status</span>
          </Link>
        </div>
      </div>
    </footer>
	</body>
</html>
